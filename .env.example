# Groww Weekly Review Pulse — environment variables
#
# Setup:
#   1. Copy this file:  cp .env.example .env   (Windows: copy .env.example .env)
#   2. Fill in GROQ_API_KEY below
#   3. Never commit .env (it is gitignored)
#
# Get a Groq API key: https://console.groq.com/keys

# Required for pulse analyze (Phase 2+ LLM summarization)
GROQ_API_KEY=

# Required for pulse deliver-docs (hosted Google MCP on Railway)
# Generate on the server or use: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_API_KEY=

# Google Doc for Weekly Review Pulse — Groww (deliver-docs target)
# Full URL or bare ID from https://docs.google.com/document/d/<DOC_ID>/edit
GOOGLE_DOC_ID=

# Email teaser delivery (deliver-email) — overrides config/groww.yaml email section
# Comma-separated for multiple recipients
PULSE_EMAIL_RECIPIENTS=
# draft | send (hosted MCP currently supports draft only)
PULSE_EMAIL_MODE=draft

# Optional: Hugging Face cache directory for BGE embedding model downloads
# HF_HOME=

# Optional: override Groq base URL (leave unset for default)
# GROQ_BASE_URL=

# --- GitHub Actions (Settings → Secrets and variables → Actions) ---
# Mirror the .env keys above as repository secrets for scheduled weekly runs:
#   GROQ_API_KEY, MCP_API_KEY, GOOGLE_DOC_ID, PULSE_EMAIL_RECIPIENTS, PULSE_EMAIL_MODE
